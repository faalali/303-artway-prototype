# ILA Gallery Artist Database - Environmental Config Template
# Copy this file to '.env.production' or '.env.development' and fill in active keys.

# 1. Google Sheets Apps Script URL (ends in /exec)
VITE_GOOGLE_SHEETS_SCRIPT_URL=https://script.google.com/macros/s/xxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec

# 2. Secure Token validation key (exchanged between React and Apps Script doPost/doGet)
# Generate a cryptographically secure string (e.g. openssl rand -hex 32)
VITE_API_ACCESS_TOKEN=your_secure_hex_authorization_token_goes_here

# 3. Google Maps JavaScript API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

